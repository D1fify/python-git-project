# Режим отладки (True/False)
DEBUG=False

# Максимальное количество попыток
MAX_RETRIES=3

# Таймаут в секундах
TIMEOUT=30

# Размер пакета при обработке
BATCH_SIZE=100

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# PostgreSQL настройки
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=myapp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Тип активной БД (sqlite/postgres)
ACTIVE_DB=sqlite

# API ключи
API_KEY=
API_SECRET=
